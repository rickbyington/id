<% content_for :title, "Mailbox" %>
<%= render "devise/shared/flash" %>
<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4 mb-0">Mailbox</h1>
      <% if @deliveries.any? %>
        <%= button_to "Clear all", clear_mailbox_path, method: :delete, class: "btn btn-outline-danger btn-sm", form: { data: { turbo_confirm: "Clear all mail?" } } %>
      <% end %>
    </div>
    <p class="text-muted small">Emails sent when using the test delivery method (no SMTP configured).</p>

    <% if @deliveries.any? %>
      <div class="list-group">
        <% @deliveries.each_with_index do |mail, i| %>
          <% display_index = @deliveries.size - i %>
          <%= link_to mailbox_delivery_path(display_index), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-start" do %>
            <div class="ms-2 me-auto">
              <div class="fw-bold"><%= mail.subject.presence || "(no subject)" %></div>
              <small class="text-muted">
                To: <%= Array(mail.to).join(", ") %>
                <% if mail.date.present? %>
                  · <%= mail.date.to_fs(:long) %>
                <% end %>
              </small>
            </div>
            <span class="badge bg-secondary rounded-pill">#<%= display_index %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info mb-0">No mail yet. Mail sent without SMTP will appear here.</div>
    <% end %>

    <div class="mt-3">
      <%= link_to "← Back", root_path, class: "btn btn-link btn-sm px-0" %>
    </div>
  </div>
</div>
