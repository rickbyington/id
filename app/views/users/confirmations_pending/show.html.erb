<div class="row justify-content-center">
  <div class="col-12 col-sm-10 col-md-6 col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title h4 mb-4 text-center">Check your email</h2>

        <p class="text-center mb-4">
          We sent you an email with a link to confirm your account.
        </p>
        <p class="text-center text-muted small mb-4">
          Click the link in that email to confirm your account and sign in. If you don't see it, check your spam folder.
        </p>

        <hr class="my-4">
        <div class="text-center small text-muted">
          <%= link_to "Sign in", new_user_session_path, class: "text-decoration-none me-3" %>
          <%= link_to "Didn't receive the email?", new_user_confirmation_path, class: "text-decoration-none" %>
        </div>
      </div>
    </div>
  </div>
</div>
