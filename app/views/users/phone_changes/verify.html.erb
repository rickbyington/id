<div class="row justify-content-center">
  <div class="col-12 col-sm-10 col-md-6 col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <%= render "devise/shared/flash" %>
        <h2 class="card-title h4 mb-4 text-center">Confirm your new number</h2>

        <p class="text-muted small text-center mb-4">We sent a 6-digit code to <strong><%= session[:phone_change_phone] %></strong>. Enter it below.</p>

        <%= form_with url: confirm_user_phone_change_path, method: :post do |f| %>
          <div class="mb-4">
            <label for="code" class="form-label">Verification code</label>
            <%= f.text_field :code, class: "form-control form-control-lg", id: "code", inputmode: "numeric", pattern: "[0-9]{6}", maxlength: "6", placeholder: "123456", autocomplete: "one-time-code", autofocus: true, required: true %>
          </div>

          <%= f.submit "Confirm", class: "btn btn-primary btn-lg w-100 mb-2" %>
        <% end %>

        <hr class="my-4">
        <div class="text-center small text-muted">
          Didn't receive a code?
          <%= link_to "Resend", resend_user_phone_change_path, class: "text-decoration-none me-2" %>
          ·
          <%= link_to "Use a different number", new_user_phone_change_path, class: "text-decoration-none ms-2" %>
        </div>
      </div>
    </div>
  </div>
</div>
