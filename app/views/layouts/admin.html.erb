<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) ? "#{content_for(:title)} | Admin" : "Admin | Id" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" crossorigin="anonymous">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminTopNav" aria-controls="adminTopNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminTopNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><%= link_to "Admin", admin_root_path, class: "nav-link" %></li>
            <%# Same links as left sidebar — visible only on small screens (sidebar hidden) %>
            <li class="nav-item d-lg-none"><%= link_to "Applications", admin_oauth_applications_path, class: "nav-link" %></li>
            <li class="nav-item d-lg-none"><%= link_to "Permissions", admin_permissions_path, class: "nav-link" %></li>
            <li class="nav-item d-lg-none"><%= link_to "Users", admin_users_path, class: "nav-link" %></li>
            <li class="nav-item d-lg-none"><%= link_to "User permissions", admin_user_permissions_path, class: "nav-link" %></li>
          </ul>
          <ul class="navbar-nav">
            <% if user_signed_in? %>
              <% profile_label = [current_user.first_name, current_user.last_name].compact.join(" ").presence || current_user.email %>
              <li class="nav-item"><%= link_to profile_label, root_path, class: "nav-link", title: "Profile" %></li>
              <li class="nav-item"><%= link_to "Sign out", destroy_user_session_path, class: "nav-link", data: { turbo_method: :delete } %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container-fluid">
      <div class="row">
        <aside class="col-lg-2 px-0 bg-light border-end min-vh-100 d-none d-lg-block">
          <nav class="nav flex-column py-3">
            <%= link_to admin_oauth_applications_path, class: "nav-link px-4 py-2 d-flex align-items-center #{request.path.start_with?(admin_oauth_applications_path) ? 'active bg-white border-start border-3 border-primary' : 'text-dark'}" do %>
              <i class="bi bi-app-indicator me-2"></i>Applications
            <% end %>
            <%= link_to admin_permissions_path, class: "nav-link px-4 py-2 d-flex align-items-center #{request.path.start_with?(admin_permissions_path) ? 'active bg-white border-start border-3 border-primary' : 'text-dark'}" do %>
              <i class="bi bi-shield-lock me-2"></i>Permissions
            <% end %>
            <%= link_to admin_users_path, class: "nav-link px-4 py-2 d-flex align-items-center #{request.path.start_with?(admin_users_path) ? 'active bg-white border-start border-3 border-primary' : 'text-dark'}" do %>
              <i class="bi bi-people me-2"></i>Users
            <% end %>
            <%= link_to admin_user_permissions_path, class: "nav-link px-4 py-2 d-flex align-items-center #{request.path.start_with?(admin_user_permissions_path) ? 'active bg-white border-start border-3 border-primary' : 'text-dark'}" do %>
              <i class="bi bi-person-check me-2"></i>User permissions
            <% end %>
          </nav>
        </aside>
        <main class="col-12 col-lg-10 py-4">
          <% if notice.present? %>
            <div class="alert alert-success" role="alert"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="alert alert-danger" role="alert"><%= alert %></div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>
</html>
