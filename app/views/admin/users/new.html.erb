<% content_for :title, "New user" %>
<p><%= link_to "← Users", admin_users_path, class: "text-decoration-none" %></p>
<h1 class="h3 mb-3">New user</h1>

<%= form_with model: @user, url: admin_users_path, local: true do |f| %>
  <%= render "form", f: f %>
  <div class="d-flex gap-2 mt-3">
    <%= f.submit "Create user", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_users_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
