<% content_for :title, @user.email %>
<p class="mb-2"><%= link_to "← Users", admin_users_path, class: "text-decoration-none small" %></p>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><%= @user.email %></h1>
  <%= link_to edit_admin_user_path(@user), class: "btn btn-outline-primary btn-sm" do %><i class="bi bi-pencil me-1"></i>Edit<% end %>
</div>

<dl class="row">
  <dt class="col-sm-3">Email</dt>
  <dd class="col-sm-9"><%= @user.email %></dd>
  <dt class="col-sm-3">Admin</dt>
  <dd class="col-sm-9"><%= @user.admin? ? "Yes" : "No" %></dd>
  <dt class="col-sm-3">First name</dt>
  <dd class="col-sm-9"><%= @user.first_name.presence || "—" %></dd>
  <dt class="col-sm-3">Last name</dt>
  <dd class="col-sm-9"><%= @user.last_name.presence || "—" %></dd>
  <dt class="col-sm-3">Permissions</dt>
  <dd class="col-sm-9">
    <% if @user.permissions.any? %>
      <ul class="mb-0">
        <% @user.user_permissions.includes(:permission).each do |up| %>
          <li><%= up.permission.name %><%= " (#{up.permission.value})" if up.permission.value.present? %> — <%= button_to admin_user_permission_path(up), method: :delete, form: { data: { turbo_confirm: "Remove?" } }, class: "btn btn-sm btn-outline-danger", title: "Remove" do %><i class="bi bi-trash"></i><% end %></li>
        <% end %>
      </ul>
    <% else %>
      —
    <% end %>
    <%= link_to new_admin_user_permission_path(user_id: @user.id), class: "btn btn-sm btn-outline-primary mt-2" do %><i class="bi bi-plus-lg me-1"></i>Add permission<% end %>
  </dd>
</dl>

<div class="pt-4 mt-4 border-top">
  <%= button_to admin_user_path(@user), method: :delete, form: { data: { turbo_confirm: "Are you sure? This cannot be undone." } }, class: "btn btn-outline-danger" do %><i class="bi bi-trash me-1"></i>Delete<% end %>
</div>
