<% content_for :title, "Users" %>
<h1 class="h3 mb-3">Users</h1>
<p><%= link_to "New user", new_admin_user_path, class: "btn btn-primary" %></p>

<div class="table-responsive">
  <table class="table table-striped table-bordered">
    <thead class="table-light">
      <tr>
        <th>Email</th>
        <th>Name</th>
        <th>Admin</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= link_to user.email, admin_user_path(user), class: "text-decoration-none fw-medium" %></td>
          <td><%= [user.first_name, user.last_name].compact.join(" ").presence || "—" %></td>
          <td><%= user.admin? ? "Yes" : "—" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
