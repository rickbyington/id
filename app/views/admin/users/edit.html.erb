<% content_for :title, "Edit #{@user.email}" %>
<p><%= link_to "← Users", admin_users_path, class: "text-decoration-none" %></p>
<h1 class="h3 mb-3">Edit user</h1>

<%= form_with model: @user, url: admin_user_path(@user), method: :patch, local: true do |f| %>
  <%= render "form", f: f %>
  <div class="d-flex gap-2 mt-3">
    <%= f.submit "Update user", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_user_path(@user), class: "btn btn-outline-secondary" %>
  </div>
<% end %>
