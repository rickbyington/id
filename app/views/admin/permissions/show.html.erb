<% content_for :title, @permission.name %>
<p class="mb-2"><%= link_to "← Permissions", admin_permissions_path, class: "text-decoration-none small" %></p>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><%= @permission.name %><%= " (#{@permission.value})" if @permission.value.present? %></h1>
  <%= link_to edit_admin_permission_path(@permission), class: "btn btn-outline-primary btn-sm" do %><i class="bi bi-pencil me-1"></i>Edit<% end %>
</div>

<dl class="row">
  <dt class="col-sm-3">Name</dt>
  <dd class="col-sm-9"><%= @permission.name %></dd>
  <dt class="col-sm-3">Value</dt>
  <dd class="col-sm-9"><%= @permission.value.presence || "—" %></dd>
  <dt class="col-sm-3">Users with this permission</dt>
  <dd class="col-sm-9"><%= @permission.users.count %></dd>
</dl>

<div class="pt-4 mt-4 border-top">
  <%= button_to admin_permission_path(@permission), method: :delete, form: { data: { turbo_confirm: "Are you sure? This cannot be undone." } }, class: "btn btn-outline-danger" do %><i class="bi bi-trash me-1"></i>Delete<% end %>
</div>
