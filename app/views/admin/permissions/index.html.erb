<% content_for :title, "Permissions" %>
<h1 class="h3 mb-3">Permissions</h1>
<p><%= link_to "New permission", new_admin_permission_path, class: "btn btn-primary" %></p>

<div class="table-responsive">
  <table class="table table-striped table-bordered">
    <thead class="table-light">
      <tr>
        <th>Name</th>
        <th>Value</th>
      </tr>
    </thead>
    <tbody>
      <% @permissions.each do |permission| %>
        <tr>
          <td><%= link_to permission.name, admin_permission_path(permission), class: "text-decoration-none fw-medium" %></td>
          <td><%= permission.value.presence || "—" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
