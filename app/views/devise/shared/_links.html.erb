<hr class="my-4">
<div class="text-center small text-muted">
  <%- if controller_name != 'sessions' && controller_name != 'phone_sessions' %>
    <%= link_to "Sign in", new_user_session_path, class: "text-decoration-none me-3" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' && controller_name != 'phone_registrations' %>
    <%= link_to "Sign up", new_user_registration_path, class: "text-decoration-none me-3" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-decoration-none" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <br class="mt-2">
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-decoration-none d-block mt-2" %>
  <% end %>
</div>
