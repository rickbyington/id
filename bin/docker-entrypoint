#!/usr/bin/env ruby
# frozen_string_literal: true

# First startup: if no secrets file exists, generate SECRET_KEY_BASE and OIDC key.
# Load the file into ENV so the app can boot. Optionally run db:prepare for rails server, then exec.
# Require /rails/storage to be a mounted volume so data persists (set REQUIRE_STORAGE_MOUNT=0 to skip).

require_relative "../lib/docker_entrypoint"

rails_root = File.expand_path("..", __dir__)
storage_dir = File.join(rails_root, "storage")
secrets_file = ENV.fetch("SECRETS_FILE", File.join(storage_dir, "secrets.env"))

begin
  DockerEntrypoint.check_storage_mount!(storage_dir, env: ENV)
rescue DockerEntrypoint::StorageCheckError => e
  warn "ERROR: #{e.message}"
  exit 1
end

if DockerEntrypoint.ensure_secrets_file!(secrets_file, env: ENV) == :created
  puts "First run: generating secrets into #{secrets_file}"
end

DockerEntrypoint.load_secrets_file!(secrets_file, env: ENV)

if DockerEntrypoint.run_server_setup?(ARGV)
  system(File.join(rails_root, "bin/rails"), "db:prepare") || exit($?.exitstatus)
  script = File.join(rails_root, "script", "create_initial_admin.rb")
  system(File.join(rails_root, "bin/rails"), "runner", script) if File.file?(script)
end

exec(ARGV[0], *ARGV[1..])
