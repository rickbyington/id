# Copy to .env and set values. Used by docker-compose (app + Postgres).
# Do not commit .env.
# All secrets via ENV; no Rails credentials or config/master.key.

# Required. Secrets for app + OAuth/OIDC (JWT access tokens use same key as OIDC, RS256):
# - SECRET_KEY_BASE:   openssl rand -hex 64
# - OIDC_PRIVATE_KEY:  PEM string (newlines as \n in .env). Generate: openssl genrsa 2048
SECRET_KEY_BASE=
OIDC_PRIVATE_KEY=

# DB password for production (Compose). App receives DATABASE_PASSWORD from this; default "postgres".
POSTGRES_PASSWORD=postgres

# Optional: SMTP (to send real email — confirmations, password reset, etc.).
# If unset, mail is not delivered (test mailbox in dev; no send in production).
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_USER_NAME=
# SMTP_PASSWORD=

# Optional: host used in links inside emails (e.g. https://id.example.com).
# ACTION_MAILER_DEFAULT_HOST=id.example.com

# SignalWire SMS (required for phone number sign-in / sign-up).
# Get these from your SignalWire dashboard: https://signalwire.com
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com
SIGNALWIRE_FROM_NUMBER=+15551234567
